#!/bin/sh
# ai-blame global post-commit hook (dispatcher)
# Runs ai-blame logic, then forwards to the repo's own post-commit hook if present.

# --- ai-blame: move pending attribution to commit archive ---
PENDING=".git/ai-blame/pending.jsonl"
if [ -f "$PENDING" ] && [ -s "$PENDING" ]; then
    SHA=$(git rev-parse HEAD)
    COMMIT_DIR=".git/ai-blame/commits"
    mkdir -p "$COMMIT_DIR"
    mv "$PENDING" "$COMMIT_DIR/$SHA.jsonl"
fi

# --- dispatch to per-repo hook if it exists ---
REPO_HOOK="$(git rev-parse --git-dir)/hooks/post-commit"
if [ -x "$REPO_HOOK" ]; then
    exec "$REPO_HOOK" "$@"
fi
