#!/bin/sh
# ai-blame global post-commit hook (dispatcher)
# Writes pending AI attribution to git notes, then forwards to per-repo hook.

PENDING=".git/ai-blame/pending.jsonl"
if [ -f "$PENDING" ] && [ -s "$PENDING" ]; then
    # Write pending data as a git note on HEAD
    git notes --ref=ai-blame add --no-separator -F "$PENDING" HEAD 2>/dev/null || \
    git notes --ref=ai-blame append --no-separator -F "$PENDING" HEAD 2>/dev/null
    rm -f "$PENDING"
fi

# --- dispatch to per-repo hook if it exists ---
REPO_HOOK="$(git rev-parse --git-dir)/hooks/post-commit"
if [ -x "$REPO_HOOK" ]; then
    exec "$REPO_HOOK" "$@"
fi
